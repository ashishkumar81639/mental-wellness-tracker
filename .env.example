# Neon Postgres connection string - get it from https://neon.tech (Project -> Connection Details)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# DeepSeek API key - get it from https://platform.deepseek.com
DEEPSEEK_API_KEY=

# JWT secret - generate with: openssl rand -base64 32
JWT_SECRET=

# Voice providers (optional - app works without voice)
# Assembly AI - get it from https://assemblyai.com (STT only; standalone TTS not available)
ASSEMBLY_API_KEY=

# Sarvam AI - get it from https://sarvam.ai (STT + TTS, best Hindi quality)
SARVAM_API_KEY=

# Active voice providers
# STT: assembly (real-time) | sarvam (relay)
# TTS: sarvam (assembly standalone TTS is deprecated; use sarvam)
STT_PROVIDER=assembly
TTS_PROVIDER=sarvam

# Resend (transactional email: OTP + password reset)
# Get API key at https://resend.com/api-keys
# Domain verified at https://resend.com/domains (send.yaarhelp.in subdomain)
RESEND_API_KEY=
EMAIL_FROM=Yaar <noreply@send.yaarhelp.in>
# sprint: app URL for email links. Set to prod domain on Vercel.
APP_BASE_URL=http://localhost:3000
